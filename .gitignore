# Note: git cannot re-include a file when a parent directory is excluded.
# For this reason the Optuna trial directories are NOT excluded as folders,
# only their heavy content — so the validations.txt files, which are the
# experimental results, stay tracked.

# ── Data and derived features (non-redistributable, multi-GB) ──────────────────
dataset/features/
dataset/pose/
dataset/tssi_cache/
dataset/annotations/
dataset/i3d_features_rwth*/
dataset/checkpoints/

# The full feature copy lives here (1.8 GB): never commit it.
code/signformer/data/
code/csrl_skeleton/data/
phoenix14t.pami0.*
Phoenix-2014T.*
base_annotations/

# Verbose training logs
*.log

# ── Checkpoints (published as GitHub Releases, see dataset/DATA.md) ────────
*.ckpt
*.pt
*.pth

# ── Training artefacts ───────────────────────────────────────────────────
**/tensorboard/
events.out.tfevents.*
**/gls/
*.hyp.gls
*_results.pkl
training_curves.png
*.png.tmp

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/

# ── OS / editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# smoke-test configs generated on the fly
code/distillation/_smoke_*.yaml

# training output (never the published checkpoints)
runs/

# Stray training / Optuna trial directories (organised runs live in runs/)
code/distillation/optuna_fd_*
code/distillation/scratch_*
code/distillation/warm_*
code/signformer/optuna_trial_*
code/signformer/sign_sample/
dataset/features/transformer_feats/
